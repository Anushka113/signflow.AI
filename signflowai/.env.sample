# ── Gemini (AI Chatbot) ──
GEMINI_API_KEY=AIzaYOUR_GEMINI_KEY_HERE

# ── ElevenLabs (Human Voice TTS) ──
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE

# ── MongoDB Atlas (Chat History) ──
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/signflowai?retryWrites=true&w=majority
